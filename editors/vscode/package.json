{
  "name": "thunderlang",
  "displayName": "ThunderLang",
  "description": "Syntax highlighting, diagnostics, completion, and hover for ThunderLang via the ThunderLang Language Server.",
  "version": "0.4.1",
  "publisher": "skillstech",
  "license": "Apache-2.0",
  "homepage": "https://thunderlang.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkillsTechTalk/intent-language.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:thunder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "thunder",
        "aliases": [
          "ThunderLang",
          "thunder"
        ],
        "extensions": [
          ".thunder",
          ".tl",
          ".intent"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "thunder",
        "scopeName": "source.thunder",
        "path": "./syntaxes/thunder.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "ThunderLang",
      "properties": {
        "thunderlang.serverPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Command or script that provides the ThunderLang language server. Leave empty to auto-detect: a workspace-local `thunder` binary or compiler checkout first, then `thunder` on your PATH. A value ending in `.js`, `.mjs`, or `.cjs` is launched as `node <path> lsp`; any other value is launched as `<command> lsp`."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.4.0"
  }
}
