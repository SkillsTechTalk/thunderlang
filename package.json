{
  "name": "thunderlang-site",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Official website for ThunderLang, an intent-oriented programming language for the age of AI, by Skills Tech Talk, LLC.",
  "scripts": {
    "dev": "next dev -p 5187",
    "build": "next build",
    "start": "next start -p 5187",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "intent:check": "node scripts/intent-check.mjs",
    "intent:test": "node --test compiler",
    "docs:check": "node scripts/docs-check.mjs",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "schema:emit": "node compiler/src/cli.mjs schema > compiler/intent-graph.schema.json",
    "schema:check": "node scripts/schema-check.mjs",
    "diagnostics:emit": "node scripts/diagnostics-doc.mjs --write",
    "diagnostics:check": "node scripts/diagnostics-doc.mjs --check",
    "fmt:check": "node compiler/src/cli.mjs fmt . --check",
    "atlas:build": "node scripts/build-atlas.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3"
  }
}
